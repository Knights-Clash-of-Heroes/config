{
  "name": "@kcoh/config",
  "version": "0.1.0",
  "type": "commonjs",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist/*",
    "!/**/__tests__"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "ts-node ./src/index.ts",
    "format": "prettier --write \"src/**/*.ts\"",
    "lint": "eslint \"src/**/*.ts\" --fix",
    "test": "vitest",
    "test:cov": "vitest run --coverage"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "kcoh",
    "knights-clash-of-heroes",
    "knights-battle-of-heroes",
    "рыцарская-битва-героев"
  ],
  "author": "Marcuth",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@vitest/coverage-v8": "^4.1.4",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-unused-imports": "^4.4.1",
    "prettier": "^3.8.3",
    "prettier-plugin-sort-imports": "^1.8.11",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3",
    "vitest": "^4.1.4"
  }
}
