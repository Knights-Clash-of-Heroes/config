    "campaign_quotes": [
        {
            "id": 1,
            "character_id": 1,
            "quote_key": "campaign_quote_1_quote",
            "quote": "It's quiet as the grave - no birdsong, no voices... Something is wrong here... Keep alert!"
        },
        {
            "id": 2,
            "character_id": 1,
            "quote_key": "campaign_quote_2_quote",
            "quote": "Behold, a solider of the anchient Legion! Something evil has invoked the fallen warrior with dark magic. We have to grant the poor wretch peace."
        },
        {
            "id": 3,
            "character_id": 1,
            "quote_key": "campaign_quote_3_quote",
            "quote": "Necromancer! I feel the evil oozing from him. We'll put an end his unholy crimes!"
        },
        {
            "id": 4,
            "character_id": 2,
            "quote_key": "campaign_quote_4_quote",
            "quote": "Ah, sssir Roland, a noble catch! Mistress ssshall be glad... Come meet hilt of  my ssscythe..."
        },
        {
            "id": 5,
            "character_id": 1,
            "quote_key": "campaign_quote_5_quote",
            "quote": "You'll meet mine first, Necromancer!"
        },
        {
            "id": 6,
            "character_id": 2,
            "quote_key": "campaign_quote_6_quote",
            "quote": "You threaten me, a ssservant of the great Morgana? Phatetic mortal! WARRIORSSS OF THE LEGION! ARISE!"
        },
        {
            "id": 7,
            "character_id": 2,
            "quote_key": "campaign_quote_7_quote",
            "quote": "Farewell, fool. Death has come to calim you!"
        },
        {
            "id": 8,
            "character_id": 1,
            "quote_key": "campaign_quote_8_quote",
            "quote": "The Necromancer fled! I doubt for long, however..."
        }
    ], // falas durante a campanha
